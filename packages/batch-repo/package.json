{
  "name": "@pharmacare/batch-repo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude '**/*.perf.test.ts' --exclude 'node_modules/**' --exclude 'dist/**'",
    "test:perf": "vitest run src/perf.test.ts --pool=forks --poolOptions.forks.singleFork=true",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pharmacare/shared-types": "*",
    "@pharmacare/shared-db": "*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
