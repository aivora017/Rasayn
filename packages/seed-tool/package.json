{
  "name": "@pharmacare/seed-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "pharmacare-seed": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "seed": "node --import tsx/esm src/cli.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pharmacare/shared-db": "*",
    "@pharmacare/shared-types": "*",
    "@pharmacare/search-repo": "*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
