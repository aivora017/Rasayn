{
  "name": "@pharmacare/gmail-inbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./repo": {
      "types": "./dist/repo.d.ts",
      "import": "./dist/repo.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pharmacare/shared-types": "*",
    "@pharmacare/shared-db": "*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@types/better-sqlite3": "^7.6.11"
  }
}